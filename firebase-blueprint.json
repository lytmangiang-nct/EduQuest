{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile for leaderboard and progress tracking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "User's public display name." },
        "xp": { "type": "number", "description": "Total experience points." },
        "avatar": { "type": "string", "description": "User's chosen avatar emoji." },
        "streak": { "type": "number", "description": "Current login streak." },
        "completedTopicsCount": { "type": "number", "description": "Number of topics completed." },
        "settings": { "type": "object", "description": "User UI settings." },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last time the profile was updated." }
      },
      "required": ["uid", "displayName", "xp", "streak", "completedTopicsCount"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles for the leaderboard."
    }
  }
}
