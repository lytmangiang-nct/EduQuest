rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required) - Unique user ID
    //   - displayName: string (required) - User's public name (1-20 chars)
    //   - xp: number (required) - Total XP (must be >= 0)
    //   - avatar: string (optional) - Avatar emoji
    //   - lastUpdated: timestamp (optional) - Last update time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'xp']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 20 &&
             data.xp is number && data.xp >= 0;
    }

    match /users/{uid} {
      // Allow everyone to read the leaderboard
      allow read: if true;
      
      // Allow users to create/update their own profile
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }
  }
}
