rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required) - Unique user ID
    //   - displayName: string (required) - User's public name (1-50 chars)
    //   - xp: number (required) - Total XP (must be >= 0)
    //   - avatar: string (optional) - Avatar emoji
    //   - streak: number (required) - Current login streak
    //   - completedTopicsCount: number (required) - Number of topics completed
    //   - coins: number (optional) - User's coins
    //   - createdAt: string (optional) - ISO date string
    //   - settings: map (optional) - User UI settings
    //   - lastUpdated: timestamp (optional) - Last update time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'xp', 'streak', 'completedTopicsCount']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 50 &&
             data.xp is number && data.xp >= 0 &&
             data.streak is number && data.streak >= 0 &&
             data.completedTopicsCount is number && data.completedTopicsCount >= 0 &&
             (!('avatar' in data) || (data.avatar is string && data.avatar.size() <= 200)) &&
             (!('coins' in data) || (data.coins is number && data.coins >= 0)) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('settings' in data) || data.settings is map) &&
             (!('lastUpdated' in data) || data.lastUpdated is timestamp);
    }

    match /users/{uid} {
      // Allow authenticated users to read the leaderboard
      allow read: if isAuthenticated();
      
      // Allow users to create/update their own profile
      allow create: if isOwner(uid) && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
